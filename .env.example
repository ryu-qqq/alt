# alt — 환경변수 템플릿
#
# 사용법:
#   cp .env.example .env
#   # .env 를 열어 OPENAI_API_KEY 값 채우기
#   docker compose up --build
#
# .env 는 .gitignore 에 의해 커밋되지 않는다.

# OpenAI API 키 (옵셔널).
# - 미설정 / 빈 값 시 NoOpLlmClient 가 활성화되어 부팅은 정상, summary 만 null.
# - 설정 시 GET /api/v1/subscriptions/history 응답에 자연어 요약 포함.
OPENAI_API_KEY=
